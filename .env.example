GROQ_API_KEY=replace-with-your-groq-api-key
SENTINELX_API_KEY=replace-with-a-long-random-api-key
SENTINELX_ADMIN_EMAIL=admin@sentinelx.local
SENTINELX_ADMIN_PASSWORD=replace-with-a-strong-admin-password
SENTINELX_ALLOW_REGISTRATION=false
SENTINELX_ENV=production
SENTINELX_DEMO_MODE=false
SENTINELX_CORS_ORIGINS=http://localhost:3000
SENTINELX_ELASTICSEARCH_ENABLED=true
SENTINELX_ELASTICSEARCH_INDEX=sentinelx-logs
SENTINELX_ALERT_WEBHOOK_URL=
SENTINELX_OIDC_ENABLED=false
SENTINELX_OIDC_ISSUER=
SENTINELX_OIDC_CLIENT_ID=
SENTINELX_OIDC_AUTHORIZATION_URL=
SENTINELX_OIDC_TOKEN_URL=
SENTINELX_SLA_CRITICAL_MINUTES=15
SENTINELX_SLA_HIGH_MINUTES=60
SENTINELX_SLA_MEDIUM_MINUTES=240
SENTINELX_SLA_LOW_MINUTES=1440
NEXT_PUBLIC_API_URL=http://localhost:8000
SENTINELX_DATABASE_URL=sqlite:///./data/sentinelx.db
POSTGRES_URL=postgresql://sentinel:sentinel@postgres:5432/sentinelx
